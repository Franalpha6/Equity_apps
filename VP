def recor(dato):
    if(str(dato)!= "None"):
        dato = str(dato)[0:2] 
    return dato

def verif(dato):
    dato = str(dato)
    if(re.findall("index",dato) != []):
        n = 'Eliminar' 
    elif(re.findall("Index",dato) != []):
        n = 'Eliminar'
    elif(re.findall("Com",dato) != []):
        n = 'Eliminar'
    elif(re.findall("PUT",dato) != []):
        
        n = 'Eliminar'
    elif(re.findall("CALL",dato) != []):
        
        n = 'Eliminar'
    elif(dato == "-" or dato == "ISIN" or dato == "Name"):
        
        n = 'Eliminar'
    else:
        n = 'Mantener'
    return n

