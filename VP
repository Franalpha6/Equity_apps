def nueva_fecha(mes,anio):
    if (int(mes) == 1):
        mes_n = str(12)
        anio_n = str(int(anio)-1)
    else:
        if (mes=="12" or mes == "11"):
            mes_n = str(int(mes) - 1) 
        else:
            mes_n = str(int(mes) - 1)
            mes_n = "0" + mes_n
        
        anio_n = anio
    
    return mes_n, anio_n
def float_str(x):
    if (type(x) == float or type(x)==int):
        x = int(x)
        x = str(x)
    else:
        x = str(x)
        
    return x
